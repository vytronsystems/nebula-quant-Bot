# NEBULA-QUANT — copy to .env and set for non-local or production.
# Do not commit .env. Local defaults below work for docker compose from repo root.

# Postgres (used by docker compose, bot, postgres-exporter)
POSTGRES_USER=nebula
POSTGRES_PASSWORD=nebula123
POSTGRES_DB=trading

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Telegram (optional; for alerts). If set, run docker/scripts/nq-alertmanager-telegram-enable.sh after compose up.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Binance Futures Testnet (binance-api service). Required for /api/binance/* to return CONNECTED.
BINANCE_TESTNET=true
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bot (optional overrides when running bot container)
# PG_DSN is built from POSTGRES_* in compose; override here if needed.
# REDIS_HOST=redis
# NQ_ENV=local
# NQ_VERSION=dev
